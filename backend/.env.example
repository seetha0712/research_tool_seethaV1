# Backend Environment Variables
# Copy this file to .env and fill in your actual API keys

# Security
SECRET_KEY=your-very-secure-random-secret-key-change-this-in-production
ALGORITHM=HS256

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Paid Search API Keys
TAVILY_API_KEY=tvly-your-tavily-api-key-here
SERP_API_KEY=your-serp-api-key-here

# SlidesGPT API Configuration
SLIDESGPT_API_KEY=your-slidesgpt-api-key-here

# Application Configuration
LOG_LEVEL=INFO
BACKEND_BASE=http://localhost:8000

# CORS Origins (comma-separated list for production)
# Example: CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///./genai.db

# Environment (development/production)
ENVIRONMENT=development
